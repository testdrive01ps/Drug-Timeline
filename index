const ADR_LIST=["Maculopapular rash (MP rash)","Urticaria (ลมพิษ)","Angioedema","Anaphylaxis","Fixed drug eruption (FDE)","AGEP","SJS","TEN","SJS/TEN","DRESS","Contact dermatitis","Exfoliative dermatitis","Photosensitivity","Erythema multiforme","Erythema nodosum","Pruritus (คัน)","Flushing","Serum sickness","Drug fever","Hepatotoxicity","Nephrotoxicity","QT prolongation","Neutropenia","Agranulocytosis","Thrombocytopenia","Hemolytic anemia","Aplastic anemia","Eosinophilia","Bronchospasm","Anaphylactoid reaction","Drug-induced lupus","Vasculitis","Phlebitis","Stevens-Johnson syndrome"];

let drugs=[],adrs=[],dc=0,zoomLevel=1;
const BASE_PPD=38, LABEL_W=200, DAYS_COL_W=62;

/* ════ HELPERS ════ */
function today(){return new Date().toISOString().slice(0,10);}
function fmtTHShort2(ds){
  if(!ds)return'';
  const[y,m,d]=ds.split('-');
  return`${parseInt(d)} ${TH_MON[parseInt(m)-1]} ${String(parseInt(y)+543).slice(2)}`;
}
function daysBetween(s,e){return Math.max(0,Math.round((new Date(e)-new Date(s))/86400000));}
// แปลง yyyy-mm-dd → dd/mm/yy (ปี ค.ศ. 2 หลัก เพราะ input เป็น ค.ศ.)
function dateToDDMMYY(iso){
  if(!iso)return'';
  const[y,m,d]=iso.split('-');
  return`${d}/${m}/${String(y).slice(2)}`;
}

/* ════ TABS (mobile) ════ */
function switchTab(tab){
  const pl=document.getElementById('panelLeft');
  const pr=document.getElementById('panelRight');
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  if(tab==='left'){
    pl.classList.remove('hidden'); pr.classList.add('hidden');
    document.querySelectorAll('.tab-btn')[0].classList.add('active');
  } else {
    pr.classList.remove('hidden'); pl.classList.add('hidden');
    document.querySelectorAll('.tab-btn')[1].classList.add('active');
    renderTimeline();
  }
}

/* ════ DROPDOWN ════ */
function showDD(dd,items,cb){
  if(!items.length){dd.classList.remove('open');return;}
  dd.innerHTML=items.map(i=>`<div class="di">${i}</div>`).join('');
  dd.classList.add('open');
  dd.querySelectorAll('.di').forEach((el,i)=>el.addEventListener('mousedown',e=>{e.preventDefault();cb(items[i]);}));
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.ac-wrap')&&!e.target.closest('.adr-ac'))
    document.querySelectorAll('.dropdown').forEach(d=>d.classList.remove('open'));
});

/* ════ DATE VALIDATION ════ */
function validateDates(d,startEl,endEl,errEl){
  startEl.classList.remove('err'); endEl.classList.remove('err'); errEl.style.display='none';
  if(!d.start)return true;
  if(d.start>today()){d.start=today();startEl.value=today();}
  if(!d.end)return true;
  if(d.end>today()){d.end=today();endEl.value=today();}
  if(d.end<d.start){
    errEl.textContent='วันสิ้นสุดต้องไม่ก่อนวันเริ่มต้น';
    errEl.style.display='block'; endEl.classList.add('err');
    d.end=''; endEl.value=''; return false;
  }
  return true;
}

/* ════ DRUGS ════ */
function addDrug(){
  dc++;
  const color=COLORS[(drugs.length)%COLORS.length];
  drugs.push({id:'d'+dc,color,name:'',start:today(),end:''});
  renderLeft(); renderTimeline();
}
function removeDrug(id){drugs=drugs.filter(d=>d.id!==id);renderLeft();renderTimeline();}

function renderLeft(){
  const list=document.getElementById('drugList');
