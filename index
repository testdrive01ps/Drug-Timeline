/* ════ ZOOM ════ */
function zoom(f){zoomLevel=Math.max(0.15,Math.min(12,zoomLevel*f));renderTimeline();}
function resetZoom(){zoomLevel=1;renderTimeline();}
function autoFit(){
  const range=getRange();
  if(!range)return;
  const totalDays=Math.ceil((range.mx-range.mn)/86400000);
  if(totalDays<=0)return;
  const avail=document.getElementById('panelRight').clientWidth - LABEL_W - DAYS_COL_W - 20;
  // approximate: assume ~30% days are active
  const estW=(totalDays*0.3*BASE_PPD*zoomLevel)+(totalDays*0.7*Math.max(4,BASE_PPD*zoomLevel*0.18));
  const ratio=avail/Math.max(estW,1);
  zoomLevel=Math.max(0.15,Math.min(12,zoomLevel*ratio));
  renderTimeline();
}

/* ════ TOOLTIP ════ */
const tip=document.getElementById('tooltip');
function showTip(e,html){tip.innerHTML=html;tip.style.display='block';moveTip(e);}
