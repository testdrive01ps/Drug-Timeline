  renderBadges(); renderTimeline();
}
function removeADR(id){adrs=adrs.filter(a=>a.id!==id);renderBadges();renderTimeline();}
function renderBadges(){
  document.getElementById('adrBadges').innerHTML=adrs.map(a=>`
    <div class="adr-badge">
      <span>⚠ <b>${a.type}</b> <span style="color:#d85a30;">${fmtTHShort2(a.date)}</span></span>
