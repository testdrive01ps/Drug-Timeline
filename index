/* ════ A4 PREVIEW & EXPORT ════ */
let _exportCanvas=null; // เก็บ canvas ไว้ดาวน์โหลด

function captureTimeline(scale, cb){
  const tl=document.getElementById('tlScroll');
  const target=document.getElementById('tlInner');
  const prevOv=tl.style.overflow, prevH=tl.style.height;
  tl.style.overflow='visible'; tl.style.height='auto';
  setTimeout(()=>{
    html2canvas(target,{
      backgroundColor:'#ffffff', scale,
      useCORS:true, scrollX:0, scrollY:0,
      width:target.scrollWidth, height:target.scrollHeight,
      windowWidth:target.scrollWidth, windowHeight:target.scrollHeight,
      logging:false
    }).then(canvas=>{
      tl.style.overflow=prevOv; tl.style.height=prevH;
      cb(null,canvas);
    }).catch(e=>{
      tl.style.overflow=prevOv; tl.style.height=prevH;
      cb(e);
    });
  },80);
}

// วาด canvas ของ timeline ลงบน A4 canvas (landscape 297x210mm proportional)
function drawOnA4(srcCanvas, dstCanvas){
  const dw=dstCanvas.width, dh=dstCanvas.height;
  const margin=Math.round(dw*0.015);
  const footerH=Math.round(dh*0.045);
  const usableW=dw-margin*2;
  const usableH=dh-margin-footerH;

  // scale ให้เต็มความกว้าง A4 เสมอ (ไม่สนใจ aspect ratio — ยืดตามแนวตั้งถ้าจำเป็น)
  // แต่ถ้า src สูงกว่า usableH ให้ scale ลงพอดีความสูง
  let scaleX=usableW/srcCanvas.width;
  let fw=usableW;
  let fh=Math.round(srcCanvas.height*scaleX);

  // ถ้าสูงเกิน usableH ให้ fit ด้วยความสูงแทน
  if(fh>usableH){
    const scaleY=usableH/srcCanvas.height;
    fw=Math.round(srcCanvas.width*scaleY);
    fh=usableH;
  }

  const ox=margin+Math.round((usableW-fw)/2);
  const oy=margin;

  const ctx=dstCanvas.getContext('2d');
  ctx.fillStyle='#fff'; ctx.fillRect(0,0,dw,dh);

  // วาด border กรอบ A4
  ctx.strokeStyle='#e0dfd8'; ctx.lineWidth=2;
  ctx.strokeRect(ox-1, oy-1, fw+2, fh+2);

  ctx.drawImage(srcCanvas, ox, oy, fw, fh);

  // footer line
  ctx.strokeStyle='#e0dfd8'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(margin, dh-footerH+4); ctx.lineTo(dw-margin, dh-footerH+4); ctx.stroke();

  const fSize=Math.round(dh*0.018);
  ctx.fillStyle='#888'; ctx.font=`${fSize}px 'Segoe UI',sans-serif`;
  ctx.textAlign='left';
  ctx.fillText('ADR Drug Timeline — Spontaneous ADR Recorder', margin, dh-Math.round(footerH*0.3));
  ctx.textAlign='right';
  const dateStr=new Date().toLocaleDateString('th-TH',{year:'numeric',month:'long',day:'numeric'});
  ctx.fillText(dateStr, dw-margin, dh-Math.round(footerH*0.3));
}

function showA4Preview(){
  const modal=document.getElementById('a4Modal');
  const status=document.getElementById('previewStatus');
  const previewCanvas=document.getElementById('a4Canvas');
  modal.style.display='block';
  status.textContent='กำลังสร้างพรีวิว...';
  _exportCanvas=null;

  // เปิด export mode → render ใหม่ตัวใหญ่
  exportMode=true; renderTimeline();
  setTimeout(()=>{
    captureTimeline(2,(err,srcCanvas)=>{
      // กลับโหมดปกติ
      exportMode=false; renderTimeline();
      if(err){ status.textContent='เกิดข้อผิดพลาด'; return; }
      const A4W=1200, A4H=Math.round(1200*(210/297));
      previewCanvas.width=A4W; previewCanvas.height=A4H;
      drawOnA4(srcCanvas, previewCanvas);
      status.textContent='พรีวิวเสร็จแล้ว — ปรับ zoom แล้วเปิดพรีวิวใหม่เพื่อดูผล';
    });
  },120);
}

function closePreview(){
  document.getElementById('a4Modal').style.display='none';
  _exportCanvas=null;
}

function doExportPNG(){
  const status=document.getElementById('previewStatus');
  status.textContent='⏳ กำลัง export คุณภาพสูง...';

  exportMode=true; renderTimeline();
  setTimeout(()=>{
    captureTimeline(4,(err,srcCanvas)=>{
      exportMode=false; renderTimeline();
      if(err){ status.textContent='เกิดข้อผิดพลาด กรุณาลองใหม่'; return; }
      const A4W=3508, A4H=2480;
      const outCanvas=document.createElement('canvas');
      outCanvas.width=A4W; outCanvas.height=A4H;
      drawOnA4(srcCanvas, outCanvas);
      const a=document.createElement('a');
      a.href=outCanvas.toDataURL('image/png');
      a.download='ADR_Timeline_A4.png';
      a.click();
      status.textContent='✅ ดาวน์โหลดแล้ว — Print → A4 Landscape';
    });
  },120);
}

