      if(d.start&&d.end<d.start){errEl.textContent='วันสิ้นสุดต้องไม่ก่อนวันเริ่มต้น';errEl.style.display='block';d.end='';endEl.value='';endLbl.textContent='';}
      else{errEl.style.display='none';endLbl.textContent=d.end?dateToDDMMYY(d.end):'';}
      renderTimeline();
    });
  });
}

/* ════ ADR ════ */
const adrIn=document.getElementById('adrTypeIn');
const adrDrop=document.getElementById('adrDrop');
const adrDateIn=document.getElementById('adrDateIn');
adrDateIn.value=today(); adrDateIn.max=today();
adrDateIn.addEventListener('change',()=>{if(adrDateIn.value>today())adrDateIn.value=today();});
const adrAC=()=>{
