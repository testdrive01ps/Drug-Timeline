          <input type="date" class="dstart" value="${d.start}" max="${today()}" style="flex:1;min-width:0;font-size:12px;padding:6px 4px;border:1px solid #d3d1c7;border-radius:6px;background:#fff;color:#1a1a18;outline:none;width:100%;"/>
          <span class="dstart-lbl" style="font-size:10px;color:#378ADD;font-weight:600;white-space:nowrap;min-width:46px;text-align:right;">${d.start?dateToDDMMYY(d.start):''}</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <label style="font-size:10px;color:#888780;white-space:nowrap;width:28px;flex-shrink:0;">สิ้นสุด</label>
          <input type="date" class="dend" value="${d.end}" max="${today()}" ${d.start?`min="${d.start}"`:''}  style="flex:1;min-width:0;font-size:12px;padding:6px 4px;border:1px solid #d3d1c7;border-radius:6px;background:#fff;color:#1a1a18;outline:none;width:100%;"/>
          <span class="dend-lbl" style="font-size:10px;color:#378ADD;font-weight:600;white-space:nowrap;min-width:46px;text-align:right;">${d.end?dateToDDMMYY(d.end):''}</span>
        </div>
      </div>
      <div class="date-err"></div>`;
    list.appendChild(el);
    const ni=el.querySelector('.dname'), dd=el.querySelector('.dropdown');
    const startEl=el.querySelector('.dstart'), endEl=el.querySelector('.dend'), errEl=el.querySelector('.date-err');
    const startLbl=el.querySelector('.dstart-lbl'), endLbl=el.querySelector('.dend-lbl');
    const ac=()=>{
      const q=ni.value.toLowerCase();
      const m=q?DRUG_LIST.filter(x=>x.toLowerCase().includes(q)).slice(0,15):DRUG_LIST.slice(0,15);
      if(m.length) showDD(dd,m,v=>{ni.value=v;d.name=v;dd.classList.remove('open');renderTimeline();});
      else dd.classList.remove('open');
    };
    ni.addEventListener('input',()=>{d.name=ni.value;ac();});
    ni.addEventListener('focus',ac);
    ni.addEventListener('blur',()=>{setTimeout(()=>{dd.classList.remove('open');d.name=ni.value;renderTimeline();},200);});
    startEl.addEventListener('change',e=>{
      d.start=e.target.value; endEl.min=d.start||'';
      if(d.end&&d.end<d.start){d.end='';endEl.value='';endLbl.textContent='';}
      startLbl.textContent=d.start?dateToDDMMYY(d.start):'';
      errEl.style.display='none';
      renderTimeline();
