<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>ADR Drug Timeline</title>
<meta name="description" content="Spontaneous ADR Recorder — บันทึกการแพ้ยา"/>
<meta name="theme-color" content="#378ADD"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="apple-mobile-web-app-title" content="ADR Timeline"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
/* ── RESET ── */
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background:#f5f5f2;color:#1a1a18;font-size:14px;-webkit-text-size-adjust:100%;}

/* ── HEADER ── */
.page-header{background:#fff;border-bottom:1px solid #e0dfd8;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;}
.page-titles .page-title{font-size:15px;font-weight:700;color:#1a1a18;line-height:1.2;}
.page-titles .page-sub{font-size:10px;color:#888780;margin-top:2px;}
.header-actions{display:flex;gap:6px;flex-wrap:wrap;align-items:center;}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:4px;font-size:12px;padding:6px 12px;border:1px solid #d3d1c7;border-radius:7px;background:#fff;color:#2c2c2a;cursor:pointer;white-space:nowrap;-webkit-tap-highlight-color:transparent;touch-action:manipulation;}
.btn:active{opacity:0.7;}
.btn-green{border-color:#1D9E75;color:#0F6E56;background:#f0faf6;}
.btn-blue{border-color:#378ADD;color:#185FA5;background:#f0f6fd;}
.btn-red{border-color:#E24B4A;color:#a32d2d;background:#fff5f5;}
.btn-export{border-color:#534AB7;color:#3C3489;background:#f3f2fe;}
.btn-sm{font-size:11px;padding:4px 9px;}

/* ── TABS (mobile) ── */
.tabs{display:none;border-bottom:2px solid #e0dfd8;background:#f8f7f3;}
.tab-btn{flex:1;padding:10px 4px;font-size:13px;font-weight:600;color:#888780;background:transparent;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;-webkit-tap-highlight-color:transparent;}
.tab-btn.active{color:#378ADD;border-bottom-color:#378ADD;}

/* ── MAIN LAYOUT ── */
.app{display:flex;height:calc(100vh - 52px);overflow:hidden;}

/* LEFT PANEL */
.left{width:280px;min-width:260px;max-width:280px;border-right:1px solid #e0dfd8;display:flex;flex-direction:column;background:#fff;overflow:hidden;transition:transform .25s;}
.left-head{padding:10px 13px 8px;border-bottom:1px solid #e8e7e0;background:#f8f7f3;font-size:12px;font-weight:700;color:#2c2c2a;flex-shrink:0;}
.drug-list{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:8px 9px;}

.drug-entry{margin-bottom:8px;background:#f8f7f3;border-radius:9px;border:1px solid #e0dfd8;padding:9px 10px;}
.drug-entry-top{display:flex;align-items:center;gap:6px;margin-bottom:7px;}
.color-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.ac-wrap{position:relative;flex:1;min-width:0;}
.ac-wrap input{width:100%;font-size:13px;padding:6px 9px;border:1px solid #d3d1c7;border-radius:7px;background:#fff;color:#1a1a18;outline:none;-webkit-appearance:none;}
.ac-wrap input:focus{border-color:#378ADD;box-shadow:0 0 0 2px rgba(55,138,221,0.15);}
.dropdown{position:absolute;top:calc(100% + 3px);left:0;right:0;background:#fff;border:1px solid #d3d1c7;border-radius:8px;z-index:400;max-height:180px;overflow-y:auto;display:none;box-shadow:0 6px 24px rgba(0,0,0,0.14);}
.dropdown.open{display:block;}
.di{padding:8px 11px;font-size:13px;cursor:pointer;color:#1a1a18;border-bottom:1px solid #f0efe8;}
.di:last-child{border-bottom:none;}
.di:active,.di:hover{background:#e6f1fb;}

.drug-dates{display:grid;grid-template-columns:32px minmax(0,1fr) 40px minmax(0,1fr);gap:3px 4px;align-items:center;}
.drug-dates label{font-size:10px;color:#888780;white-space:nowrap;}
.drug-dates input[type=date]{font-size:11px;padding:4px 2px;border:1px solid #d3d1c7;border-radius:6px;background:#fff;color:#1a1a18;outline:none;width:100%;min-width:0;overflow:hidden;}
.drug-dates input[type=date]:focus{border-color:#378ADD;}
.drug-dates input[type=date].err{border-color:#E24B4A;background:#fff5f5;}
.date-err{font-size:10px;color:#E24B4A;margin-top:3px;display:none;}
.btn-rm{font-size:11px;padding:4px 9px;border:1px solid #d3d1c7;border-radius:6px;background:transparent;color:#888780;cursor:pointer;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
.btn-rm:active{border-color:#E24B4A;color:#E24B4A;}
.btn-add-drug{margin:5px 9px 6px;font-size:13px;padding:8px 10px;border:1px solid #d3d1c7;border-radius:8px;background:#fff;color:#2c2c2a;cursor:pointer;width:calc(100% - 18px);text-align:left;-webkit-tap-highlight-color:transparent;}
.btn-add-drug:active{background:#f1efe8;}

/* ADR panel */
.adr-panel{border-top:1px solid #f7c1c1;padding:10px 10px 12px;background:#fdf5f5;flex-shrink:0;}
.adr-title{font-size:11px;font-weight:700;color:#a32d2d;margin-bottom:8px;}
.adr-row{display:flex;gap:6px;align-items:flex-start;flex-wrap:wrap;margin-bottom:7px;}
.adr-ac{position:relative;flex:1;min-width:140px;}
.adr-ac input{width:100%;font-size:12px;padding:6px 9px;border:1px solid #f7c1c1;border-radius:7px;background:#fff;color:#1a1a18;outline:none;-webkit-appearance:none;}
.adr-ac input:focus{border-color:#E24B4A;box-shadow:0 0 0 2px rgba(226,75,74,0.12);}
.adr-date{font-size:12px;padding:6px 6px;border:1px solid #f7c1c1;border-radius:7px;background:#fff;color:#a32d2d;outline:none;width:120px;-webkit-appearance:none;}
.adr-date:focus{border-color:#E24B4A;}
.btn-adr{font-size:12px;padding:6px 12px;border-radius:7px;background:#E24B4A;color:#fff;border:none;cursor:pointer;font-weight:700;white-space:nowrap;-webkit-tap-highlight-color:transparent;}
.btn-adr:active{background:#a32d2d;}
.adr-badges{display:flex;flex-direction:column;gap:4px;max-height:110px;overflow-y:auto;}
.adr-badge{display:flex;align-items:flex-start;gap:5px;background:#fcebeb;border:1px solid #f7c1c1;border-radius:7px;padding:5px 9px;font-size:11px;color:#a32d2d;line-height:1.4;}
.adr-bx{cursor:pointer;margin-left:auto;font-size:16px;line-height:1;color:#d85a30;flex-shrink:0;padding-left:4px;-webkit-tap-highlight-color:transparent;}

/* RIGHT PANEL */
.right{flex:1;display:flex;flex-direction:column;min-width:0;background:#fff;overflow:hidden;}
.toolbar{display:flex;align-items:center;gap:6px;padding:7px 10px;border-bottom:1px solid #e0dfd8;background:#f8f7f3;flex-wrap:wrap;flex-shrink:0;}
.tlabel{font-size:11px;color:#888780;font-weight:700;white-space:nowrap;}
.leg-wrap{display:flex;gap:8px;align-items:center;font-size:10px;color:#888780;flex-wrap:wrap;}
.leg{display:flex;align-items:center;gap:4px;}
.notice{font-size:10px;color:#1D9E75;background:#e1f5ee;border-radius:5px;padding:3px 8px;white-space:nowrap;}
.tl-scroll{flex:1;overflow:auto;-webkit-overflow-scrolling:touch;}

/* TOOLTIP */
.tooltip{position:fixed;background:#fff;border:1px solid #d3d1c7;border-radius:9px;padding:8px 12px;font-size:12px;pointer-events:none;z-index:999;display:none;box-shadow:0 4px 16px rgba(0,0,0,0.15);max-width:260px;}
.tt-t{font-weight:700;color:#a32d2d;margin-bottom:2px;}
.tt-d{font-size:10px;color:#888780;}

/* ── MOBILE: portrait ── */
@media (max-width:700px){
  html,body{font-size:15px;}
  .app{flex-direction:column;height:auto;min-height:calc(100vh - 96px);overflow:visible;}
  .tabs{display:flex;}
  .left{width:100%;max-width:100%;min-width:0;border-right:none;border-bottom:1px solid #e0dfd8;max-height:none;overflow:visible;}
  .left.hidden{display:none;}
  .right.hidden{display:none;}
  .right{height:70vmax;min-height:380px;}
  .leg-wrap{display:none;}
  .tlabel{display:none;}
  .page-sub{display:none;}
  .drug-dates{grid-template-columns:34px 1fr 44px 1fr;}
}

/* ── TABLET ── */
@media (min-width:701px) and (max-width:1024px){
  .left{width:260px;min-width:240px;}
  .leg-wrap{display:none;}
}

/* ── PRINT ── */
@media print{
  .page-header,.tabs,.toolbar,.left{display:none!important;}
  .app{height:auto;overflow:visible;}
  .right{height:auto;}
  .tl-scroll{overflow:visible;height:auto;}
  #tlInner{overflow:visible;}
}
</style>
</head>
<body>

<div class="page-header">
  <div class="page-titles">
    <div class="page-title">ADR Drug Timeline</div>
    <div class="page-sub">Spontaneous ADR Recorder — โรงพยาบาลเจ้าพระยายมราช</div>
  </div>
  <div class="header-actions">
    <button class="btn btn-green" onclick="saveState()">💾 บันทึก</button>
    <button class="btn btn-blue" onclick="loadState()">📂 โหลด</button>
    <button class="btn btn-export" onclick="showA4Preview()" id="exportBtn">📄 พรีวิว / Export PNG</button>
    <span id="saveNotice" class="notice" style="display:none;">บันทึกแล้ว ✓</span>
  </div>
</div>

<!-- tabs สำหรับ mobile -->
<div class="tabs" id="tabBar">
  <button class="tab-btn active" onclick="switchTab('left')">💊 ยา / ADR</button>
  <button class="tab-btn" onclick="switchTab('right')">📊 ไทม์ไลน์</button>
</div>

<div class="app">
  <!-- LEFT -->
  <div class="left" id="panelLeft">
    <div class="left-head">ยา (Drug)</div>
    <div class="drug-list" id="drugList"></div>
    <button class="btn-add-drug" onclick="addDrug()">+ เพิ่มยา</button>
    <div class="adr-panel">
      <div class="adr-title">⚠ บันทึกอาการแพ้ยา (ADR)</div>
      <div class="adr-row">
        <div class="adr-ac">
          <input id="adrTypeIn" type="text" placeholder="พิมพ์หรือเลือกอาการ..." autocomplete="off"/>
          <div class="dropdown" id="adrDrop"></div>
        </div>
        <input id="adrDateIn" type="date" class="adr-date"/>
        <button class="btn-adr" onclick="addADR()">+ ADR</button>
      </div>
      <div class="adr-badges" id="adrBadges"></div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="right" id="panelRight">
    <div class="toolbar">
      <span class="tlabel">ไทม์ไลน์</span>
      <button class="btn btn-sm" onclick="zoom(1.5)">＋ ขยาย</button>
      <button class="btn btn-sm" onclick="zoom(0.67)">－ ย่อ</button>
      <button class="btn btn-sm" onclick="autoFit()" style="border-color:#1D9E75;color:#0F6E56;">⊡ พอดีจอ</button>
      <div class="leg-wrap">
        <div class="leg">
          <svg width="38" height="14" style="overflow:visible"><line x1="0" y1="7" x2="30" y2="7" stroke="#378ADD" stroke-width="2"/><circle cx="0" cy="7" r="5" fill="white" stroke="#378ADD" stroke-width="2"/><circle cx="30" cy="7" r="5" fill="#378ADD" stroke="#378ADD" stroke-width="2"/></svg>
          <span>○ เริ่ม ● สิ้นสุด</span>
        </div>
        <div class="leg">
          <svg width="32" height="14" style="overflow:visible"><line x1="0" y1="7" x2="20" y2="7" stroke="#378ADD" stroke-width="2"/><circle cx="0" cy="7" r="5" fill="white" stroke="#378ADD" stroke-width="2"/><polygon points="20,3 30,7 20,11" fill="#378ADD"/></svg>
          <span style="margin-left:4px;">ยังใช้อยู่</span>
        </div>
        <div class="leg">
          <svg width="14" height="14"><line x1="7" y1="0" x2="7" y2="14" stroke="#E24B4A" stroke-width="2.5" stroke-dasharray="4,3"/></svg>
          <span>วันแพ้ยา</span>
        </div>
      </div>
    </div>
    <div class="tl-scroll" id="tlScroll">
      <div id="tlInner">
        <div style="padding:60px 20px;text-align:center;color:#b4b2a9;font-size:13px;">เพิ่มยาและวันที่เพื่อดูไทม์ไลน์</div>
      </div>
    </div>
  </div>
</div>
<!-- A4 Preview Modal -->
<div id="a4Modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:2000;overflow:auto;padding:20px;">
  <div style="max-width:860px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.3);">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:#f8f7f3;border-bottom:1px solid #e0dfd8;">
      <div>
        <div style="font-size:14px;font-weight:700;color:#1a1a18;">พรีวิว A4 Landscape</div>
        <div style="font-size:11px;color:#888780;margin-top:2px;">กราฟจะถูก scale ให้พอดีหน้า A4 — ถ้าตัวอักษรเล็กเกินให้ zoom timeline ก่อน</div>
      </div>
      <div style="display:flex;gap:8px;">
        <button onclick="doExportPNG()" style="font-size:13px;padding:7px 16px;border-radius:7px;background:#534AB7;color:#fff;border:none;cursor:pointer;font-weight:700;">⬇ ดาวน์โหลด PNG</button>
        <button onclick="closePreview()" style="font-size:13px;padding:7px 14px;border-radius:7px;background:#fff;color:#2c2c2a;border:1px solid #d3d1c7;cursor:pointer;">✕ ปิด</button>
      </div>
    </div>
    <!-- A4 landscape preview area: ratio 297:210 = 1.414:1 -->
    <div style="padding:16px;background:#888;overflow:auto;">
      <div id="a4Frame" style="width:100%;background:#fff;position:relative;box-shadow:0 2px 12px rgba(0,0,0,0.3);">
        <!-- A4 ratio box: padding-top = 210/297*100% -->
        <div style="width:100%;padding-top:70.7%;position:relative;">
          <canvas id="a4Canvas" style="position:absolute;inset:0;width:100%;height:100%;display:block;"></canvas>
        </div>
      </div>
    </div>
    <div id="previewStatus" style="padding:8px 16px;font-size:11px;color:#888780;text-align:center;border-top:1px solid #f0efe8;">กำลังสร้างพรีวิว...</div>
  </div>
</div>

