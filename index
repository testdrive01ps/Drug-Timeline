    el.innerHTML=`
      <div class="drug-entry-top">
        <div class="color-dot" style="background:${d.color}"></div>
        <div class="ac-wrap">
          <input type="text" class="dname" placeholder="พิมพ์หรือค้นหาชื่อยา..." value="${d.name}" autocomplete="off"/>
          <div class="dropdown" id="dd_${d.id}"></div>
