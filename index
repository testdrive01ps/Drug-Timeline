/* ════ RANGE ════ */
function getRange(){
  let all=[];
  drugs.forEach(d=>{if(d.start)all.push(new Date(d.start));if(d.end)all.push(new Date(d.end));});
  adrs.forEach(a=>{if(a.date)all.push(new Date(a.date));});
  if(!all.length)return null;
  let mn=new Date(Math.min(...all)),mx=new Date(Math.max(...all));
  mn.setDate(mn.getDate()-1); mx.setDate(mx.getDate()+2);
  return{mn,mx};
}

/* ════ RENDER TIMELINE ════ */
let exportMode=false;

function renderTimeline(){
  const inner=document.getElementById('tlInner');
  const active=drugs.filter(d=>d.name&&d.start);
  if(!active.length&&!adrs.length){
    inner.innerHTML='<div style="padding:60px 20px;text-align:center;color:#b4b2a9;font-size:13px;">เพิ่มยาและวันที่เพื่อดูไทม์ไลน์</div>';
    return;
  }
  const range=getRange(); if(!range)return;
  const{mn,mx}=range;
  const ppd=BASE_PPD*zoomLevel;       // px ต่อวันในช่วงยา
  const ppdGap=Math.max(4, ppd*0.18); // px ต่อวันในช่วงว่าง (บีบ)

  const totalDays=Math.ceil((mx-mn)/86400000);

  // สร้าง "active day set" — วันที่มียาใช้อยู่
  const activeDaySet=new Set();
  active.forEach(d=>{
    const s=new Date(d.start), e=d.end?new Date(d.end):new Date(mx);
    for(let cur=new Date(s);cur<=e;cur.setDate(cur.getDate()+1)){
      activeDaySet.add(cur.toISOString().slice(0,10));
    }
  });
  adrs.forEach(a=>{ if(a.date) activeDaySet.add(a.date); });

  // เพิ่ม buffer 2 วันรอบวันที่มียา ให้เส้นไม่ชิดขอบ
  const bufferedSet=new Set(activeDaySet);
  activeDaySet.forEach(ds=>{
    for(let b=-2;b<=2;b++){
      const d2=new Date(ds); d2.setDate(d2.getDate()+b);
      bufferedSet.add(d2.toISOString().slice(0,10));
    }
  });

  // คำนวณ cumulative x ของแต่ละวัน
  const allDays=[];
  const dayX={}; // dateStr → x pixel (left edge)
  let cx=0;
  for(let i=0;i<totalDays;i++){
    const d=new Date(mn); d.setDate(d.getDate()+i);
    const ds=d.toISOString().slice(0,10);
    dayX[ds]=cx;
    const w=bufferedSet.has(ds)?ppd:ppdGap;
    allDays.push({d,ds,x:cx,w});
    cx+=w;
  }
  const W=cx;

  function d2x(dateStr){
    // interpolate ถ้า dateStr ตรงกับวันใน allDays
    if(dayX[dateStr]!==undefined) return dayX[dateStr];
    // หาวันใกล้สุด
    const target=new Date(dateStr);
    const diff=Math.round((target-mn)/86400000);
    if(diff<=0) return 0;
    if(diff>=totalDays) return W;
    return dayX[allDays[diff]?.ds]||0;
  }

  const ROW_NORMAL=Math.max(52,Math.min(90,Math.floor(380/Math.max(active.length,1))));
  const ROW_EXPORT=Math.max(80,Math.min(140,Math.floor(520/Math.max(active.length,1))));
  const ROW=exportMode?ROW_EXPORT:ROW_NORMAL;
  const CY=Math.round(ROW*0.58), R=6, LW=2;

  /* month starts */
  const monthStarts=[];
  allDays.forEach(({d,x},i)=>{
    if(d.getDate()===1||i===0){
      const be=d.getFullYear()+543;
      monthStarts.push({x,label:`${TH_MON[d.getMonth()]} ${String(be).slice(2)}`});
    }
  });

  /* grid lines */
  function gridLines(){
    return allDays.map(({d,x,w},i)=>`<div style="position:absolute;left:${x}px;top:0;bottom:0;width:${w}px;border-left:1px solid ${d.getDate()===1?'#c8c6be':i%7===0?'#d3d1c7':'#eeede6'};pointer-events:none;"></div>`).join('');
  }

  /* font sizes และ element sizes scale ตาม ROW */
  const FONT=Math.max(9, Math.round(ROW*0.14));       // label วันที่บนเส้น
  const FONT_ADR=Math.max(9, Math.round(ROW*0.13));   // label ADR
  const FONT_NAME=Math.max(12, Math.round(ROW*0.18)); // ชื่อยาใน label col
  const FONT_DAY=Math.max(14, Math.round(ROW*0.22));  // ตัวเลขจำนวนวัน
  const FONT_DAY_SUB=Math.max(9, Math.round(ROW*0.12));
  const FONT_HDR=Math.max(10, Math.round(ROW*0.13));  // header วันที่
  const RR=Math.max(6, Math.round(ROW*0.09));         // circle radius
  const LWW=Math.max(2, Math.round(ROW*0.03));        // line width

  /* ADR label overlay — วาดเป็น HTML div ลอยเหนือแถวแรก */
  function adrLabelOverlay(){
    return adrs.map(a=>{
      const ax=d2x(a.date);
      const line1=a.type.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const line2=`(${fmtTHShort2(a.date)})`;
      return`<div style="position:absolute;left:${ax+5}px;bottom:4px;background:white;border:1.2px solid #f7c1c1;border-radius:4px;padding:2px 6px;white-space:nowrap;z-index:20;pointer-events:none;line-height:1.4;">
        <div style="font-size:${FONT_ADR}px;font-weight:700;color:#a32d2d;">${line1}</div>
        <div style="font-size:${Math.max(8,FONT_ADR-1)}px;color:#c0392b;">${line2}</div>
      </div>`;
    }).join('');
  }

  /* ADR SVG lines — เส้นตรง + ❗ปลายล่างอย่างเดียว */
  function adrSVGLines(rowH){
    return adrs.map(a=>{
      const ax=d2x(a.date);
      const tipHTML=`<div class='tt-t'>⚠ ${a.type}</div><div class='tt-d'>${fmtTHShort2(a.date)}</div>`;
      const symR=Math.max(9,Math.round(rowH*0.13));
      const symY=rowH-symR-2;
      return`
        <line x1="${ax}" y1="0" x2="${ax}" y2="${symY-symR}" stroke="#E24B4A" stroke-width="${LWW+0.5}"/>
        <circle cx="${ax}" cy="${symY}" r="${symR}" fill="#E24B4A" style="cursor:pointer;"
          onmouseenter="showTip(event,'${tipHTML.replace(/'/g,'&#39;').replace(/"/g,'&quot;')}')" onmouseleave="hideTip()"/>
        <text x="${ax}" y="${symY+Math.round(symR*0.6)}" text-anchor="middle" font-size="${Math.round(symR*1.4)}px" fill="white" font-family="Arial,sans-serif" font-weight="900" style="pointer-events:none;">!</text>`;
    }).join('');
  }

  /* ── HEADER row เดือน — กรองไม่ให้ซ้อน ── */
  // คำนวณ label เดือนแล้วกรองที่ซ้อนกันออก
  const filteredMonths=[];
  monthStarts.forEach(ms=>{
    if(!filteredMonths.length||ms.x-filteredMonths[filteredMonths.length-1].x>55){
      filteredMonths.push(ms);
    }
  });

  let html=`<div style="display:flex;position:sticky;top:0;background:#f8f7f3;z-index:11;border-bottom:1px solid #d3d1c7;">
    <div style="width:${LABEL_W}px;min-width:${LABEL_W}px;border-right:1px solid #e0dfd8;position:sticky;left:0;background:#f8f7f3;z-index:15;height:24px;"></div>
    <div style="position:relative;width:${W}px;flex-shrink:0;height:24px;overflow:hidden;">
      ${filteredMonths.map(ms=>`<div style="position:absolute;left:${ms.x+3}px;top:3px;font-size:${FONT_HDR+1}px;font-weight:700;color:#2c2c2a;white-space:nowrap;background:#f8f7f3;padding-right:4px;">${ms.label}</div>`).join('')}
    </div>
    <div style="width:${DAYS_COL_W}px;min-width:${DAYS_COL_W}px;border-left:1px solid #e0dfd8;"></div>
  </div>`;

  /* ── HEADER row วันที่ — adaptive ticks ── */
  const minTickPx=20;
  const tickEvery = ppd>=minTickPx ? 1
    : ppd*2>=minTickPx ? 2
    : ppd*5>=minTickPx ? 5
    : ppd*10>=minTickPx ? 10
    : ppd*15>=minTickPx ? 15
    : ppd*30>=minTickPx ? 30 : 60;

  const showDay=(d)=>{
    const dt=d.getDate();
    if(tickEvery===1) return true;
    if(tickEvery===2) return dt%2===1;
    if(tickEvery===5) return [1,5,10,15,20,25].includes(dt);
    if(tickEvery===10) return [1,10,20].includes(dt);
    if(tickEvery===15) return [1,15].includes(dt);
    return dt===1;
  };

  html+=`<div style="display:flex;position:sticky;top:24px;background:#fff;z-index:10;border-bottom:2px solid #c8c6be;">
    <div style="width:${LABEL_W}px;min-width:${LABEL_W}px;padding:3px 10px;font-size:${FONT_HDR}px;color:#888780;font-weight:700;border-right:1px solid #e0dfd8;position:sticky;left:0;background:#fff;z-index:15;">ยา</div>
    <div style="position:relative;width:${W}px;flex-shrink:0;height:24px;overflow:hidden;background:#fff;">
      ${allDays.map(({d,x,w},i)=>{
        const show=showDay(d);
        const isMon=d.getDate()===1;
        const isAct=bufferedSet.has(d.toISOString().slice(0,10));
        const borderColor=isMon?'#c8c6be':i%7===0?'#d3d1c7':'#eeede6';
        const borderW=isMon?'2px':'1px';
        const dayNum=String(d.getDate()).padStart(2,'0');
        const fs=Math.max(7,FONT_HDR-(tickEvery>5?1:0));
        return`<div style="position:absolute;left:${x}px;top:0;width:${w}px;height:24px;border-left:${borderW} solid ${borderColor};display:flex;align-items:center;justify-content:center;overflow:hidden;">
          ${(show&&isAct)||isMon?`<span style="font-size:${fs}px;color:#444441;line-height:1;white-space:nowrap;">${dayNum}</span>`:''}
        </div>`;
      }).join('')}
    </div>
    <div style="width:${DAYS_COL_W}px;min-width:${DAYS_COL_W}px;padding:3px 4px;font-size:${FONT_HDR}px;color:#888780;font-weight:700;border-left:1px solid #e0dfd8;display:flex;align-items:center;justify-content:center;text-align:center;line-height:1.2;">วันที่<br/>ใช้</div>
  </div>`;

  /* ── DRUG ROWS — จัดกลุ่มชื่อเดียวกันเป็นแถวเดียว ── */
  // จัดกลุ่ม: key = ชื่อยา, value = array ของ drug objects
  const grouped = [];
  const nameMap = {};
  active.forEach(d=>{
    const key=d.name.trim().toLowerCase();
    if(nameMap[key]!==undefined){
      grouped[nameMap[key]].segments.push(d);
    } else {
      nameMap[key]=grouped.length;
      grouped.push({name:d.name, color:d.color, segments:[d]});
    }
  });

  grouped.forEach((group, rowIdx)=>{
    const c=group.color;
    // คำนวณรวมจำนวนวันทุก segment
    const totalDays=group.segments.reduce((sum,d)=>{
      return sum+(d.end?daysBetween(d.start,d.end):daysBetween(d.start,today()));
    },0);
    const hasOngoing=group.segments.some(d=>!d.end);

    let svg='';
    group.segments.forEach((d,si)=>{
      const x1=d2x(d.start);
      const ongoing=!d.end;
      const x2=d.end?d2x(d.end):W-RR-8;
      const startLabel=fmtTHShort2(d.start);
      const endLabel=d.end?fmtTHShort2(d.end):'ปัจจุบัน';

      // เส้นหลักของ segment
      svg+=`<line x1="${x1}" y1="${CY}" x2="${x2}" y2="${CY}" stroke="${c}" stroke-width="${LWW}"/>`;
      // วงกลมใส = เริ่ม
      svg+=`<circle cx="${x1}" cy="${CY}" r="${RR}" fill="white" stroke="${c}" stroke-width="${LWW}"/>`;
      svg+=`<text x="${x1}" y="${CY-RR-4}" text-anchor="middle" font-size="${FONT}" fill="${c}" font-family="'Segoe UI',sans-serif" font-weight="600">${startLabel}</text>`;
      // ปลาย
      if(ongoing){
        const aw=Math.round(RR*2), ah=Math.round(RR*1.3);
        svg+=`<polygon points="${x2},${CY-ah} ${x2+aw},${CY} ${x2},${CY+ah}" fill="${c}"/>`;
        svg+=`<text x="${x2+aw/2}" y="${CY+RR+FONT+2}" text-anchor="middle" font-size="${FONT}" fill="${c}" font-family="'Segoe UI',sans-serif" font-weight="600">${endLabel}</text>`;
      } else {
        svg+=`<circle cx="${x2}" cy="${CY}" r="${RR}" fill="${c}" stroke="${c}" stroke-width="${LWW}"/>`;
        svg+=`<text x="${x2}" y="${CY+RR+FONT+2}" text-anchor="middle" font-size="${FONT}" fill="${c}" font-family="'Segoe UI',sans-serif" font-weight="600">${endLabel}</text>`;
      }
      // เส้นประเชื่อมระหว่าง segment (ถ้ามี segment ถัดไปที่เริ่มหลังจาก segment นี้จบ)
      if(si<group.segments.length-1 && d.end){
        const nextD=group.segments[si+1];
        if(nextD.start>d.end){
          const gapX1=d2x(d.end);
          const gapX2=d2x(nextD.start);
          svg+=`<line x1="${gapX1}" y1="${CY}" x2="${gapX2}" y2="${CY}" stroke="${c}" stroke-width="${Math.max(1,LWW-1)}" stroke-dasharray="${Math.round(RR*1.5)},${Math.round(RR*1.2)}" opacity="0.4"/>`;
        }
      }
    });

    html+=`<div style="display:flex;border-bottom:1px solid #f0efe8;height:${ROW}px;">
      <div style="width:${LABEL_W}px;min-width:${LABEL_W}px;display:flex;align-items:center;gap:7px;padding:0 10px;border-right:1px solid #f0efe8;position:sticky;left:0;background:#fff;z-index:5;">
        <div class="color-dot" style="background:${c};flex-shrink:0;width:${Math.round(RR*1.4)}px;height:${Math.round(RR*1.4)}px;border-radius:50%;"></div>
        <span style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;flex:1;font-size:${group.name.length>20?Math.max(10,FONT_NAME-2):FONT_NAME}px;font-weight:500;line-height:1.3;word-break:break-word;" title="${group.name}">${group.name||'—'}</span>
      </div>
      <div style="position:relative;width:${W}px;height:${ROW}px;flex-shrink:0;overflow:hidden;">
        ${gridLines()}
        <svg width="${W}" height="${ROW}" style="position:absolute;left:0;top:0;overflow:visible;z-index:3;">
          ${adrSVGLines(ROW)}
          ${svg}
        </svg>
        ${rowIdx===0&&adrs.length?`<div style="position:absolute;left:0;top:0;width:${W}px;height:${ROW}px;pointer-events:none;overflow:visible;z-index:10;"></div>`:''}
      </div>
      <div style="width:${DAYS_COL_W}px;min-width:${DAYS_COL_W}px;display:flex;align-items:center;justify-content:center;border-left:1px solid #f0efe8;flex-direction:column;gap:1px;">
        <span style="font-size:${FONT_DAY}px;font-weight:700;color:${c};line-height:1;">${totalDays}</span>
        <span style="font-size:${FONT_DAY_SUB}px;color:#888780;">${hasOngoing?'วัน*':'วัน'}</span>
      </div>
    </div>`;
  });

  /* ── แถว ADR label ใต้กราฟทั้งหมด ── */
  if(adrs.length){
    const labelRowH=Math.max(36, FONT_ADR*3+16);
    // วาดเส้นแนวตั้งต่อลงมาถึงแถวนี้
    const adrLineExt=adrs.map(a=>{
      const ax=d2x(a.date);
      return`<div style="position:absolute;left:${ax}px;top:0;bottom:0;width:1px;background:#E24B4A;opacity:0.25;pointer-events:none;"></div>`;
    }).join('');

    const adrLabels=adrs.map(a=>{
      const ax=d2x(a.date);
      const line1=a.type.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const line2=fmtTHShort2(a.date);
      return`<div style="position:absolute;left:${ax+5}px;top:6px;background:#fcebeb;border:1.2px solid #f7c1c1;border-radius:5px;padding:3px 8px;white-space:nowrap;pointer-events:none;line-height:1.5;">
        <div style="font-size:${FONT_ADR}px;font-weight:700;color:#a32d2d;">⚠ ${line1}</div>
        <div style="font-size:${Math.max(8,FONT_ADR-1)}px;color:#c0392b;">${line2}</div>
      </div>`;
    }).join('');

    html+=`<div style="display:flex;border-top:2px solid #f7c1c1;background:#fdf5f5;min-height:${labelRowH}px;">
      <div style="width:${LABEL_W}px;min-width:${LABEL_W}px;display:flex;align-items:center;padding:0 10px;font-size:11px;font-weight:700;color:#a32d2d;border-right:1px solid #f7c1c1;position:sticky;left:0;background:#fdf5f5;z-index:5;">⚠ อาการแพ้ยา</div>
      <div style="position:relative;width:${W}px;flex-shrink:0;min-height:${labelRowH}px;">
        ${adrLineExt}
        ${adrLabels}
      </div>
      <div style="width:${DAYS_COL_W}px;min-width:${DAYS_COL_W}px;border-left:1px solid #f7c1c1;"></div>
    </div>`;

  }

  inner.innerHTML=html;
}

